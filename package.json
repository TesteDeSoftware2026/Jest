{
  "name": "jest",
  "version": "1.0.0",
  "description": "express + jest",
  "homepage": "https://github.com/TesteDeSoftware2026/Jest#readme",
  "bugs": {
    "url": "https://github.com/TesteDeSoftware2026/Jest/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TesteDeSoftware2026/Jest.git"
  },
  "license": "ISC",
  "author": "Nickplays",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true
  }
}
